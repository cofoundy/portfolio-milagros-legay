---
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Experience from "../components/Experience.astro";
import Education from "../components/Education.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";
import "../styles/global.css";

const siteUrl = "https://milagros-legay.cofoundy.dev";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description} />
    <meta name="keywords" content="UX Writer Lima, Redactora Publicitaria, Periodista Digital, Content Design, Milagros Legay, copywriting Peru" />
    <link rel="canonical" href={`${siteUrl}/`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{siteConfig.name} - {siteConfig.title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={`${siteConfig.name} - ${siteConfig.title}`} />
    <meta property="og:description" content={siteConfig.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": siteConfig.name,
      "jobTitle": "UX Writer",
      "url": siteUrl,
      "sameAs": [siteConfig.social.linkedin],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Jesús María",
        "addressRegion": "Lima",
        "addressCountry": "PE"
      },
      "alumniOf": {
        "@type": "EducationalOrganization",
        "name": "Universidad de San Martín de Porres"
      }
    })} />
  </head>
  <body>
    <Header />
    <section>
      <Hero />
      <About />
      <Experience />
      <Education />
    </section>
    <Footer />
  </body>
</html>
